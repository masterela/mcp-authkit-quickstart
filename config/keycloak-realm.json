{
  "realm": "mcp-quickstart",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "mcp-quickstart-vscode",
      "name": "MCP Quickstart — VS Code",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost*",
        "vscode://vscode.github-authentication/*",
        "vscode-insiders://vscode.github-authentication/*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8005/*"
      },
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Example",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice123",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Example",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob123",
          "temporary": false
        }
      ]
    }
  ]
}
