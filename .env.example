# ── GitHub OAuth App credentials ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL:      http://localhost:8005
#   Callback URL:      http://localhost:8005/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_BASE_URL=http://localhost:8005

# ── Primary OIDC (Keycloak) ───────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8889/realms/mcp-quickstart
MCP_CLIENT_ID=mcp-quickstart-vscode

# ── Storage ───────────────────────────────────────────────────────────────────
TOKEN_STORAGE_MODE=redis
REDIS_URL=redis://localhost:6379

# Optional: set a stable encryption key so tokens survive restarts.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_ENCRYPTION_KEY=
