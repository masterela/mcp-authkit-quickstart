# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# These are the credentials of the OAuth App YOU registered at:
#   https://github.com/settings/developers → OAuth Apps → New OAuth App
#
#   Homepage URL:   http://localhost:8005
#   Callback URL:   http://localhost:8005/github/callback
#
# They are NOT your personal GitHub username or password.
GITHUB_OAUTH_APP_CLIENT_ID=your-oauth-app-client-id
GITHUB_OAUTH_APP_CLIENT_SECRET=your-oauth-app-client-secret

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_BASE_URL=http://localhost:8005

# ── Primary OIDC (Keycloak) ───────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8889/realms/mcp-quickstart
MCP_CLIENT_ID=mcp-quickstart-vscode

# ── Storage ───────────────────────────────────────────────────────────────────
TOKEN_STORAGE_MODE=redis
REDIS_URL=redis://localhost:6379

# Optional: set a stable encryption key so tokens survive restarts.
# Generate with: make gen-key
STORAGE_ENCRYPTION_KEY=

# ── Corporate / TLS-inspecting proxy (optional) ───────────────────────────────
# If your network uses a TLS-intercepting proxy (e.g. Netskope, Zscaler),
# point this to your corporate CA bundle so outbound HTTPS calls succeed.
# The server reads this at startup; leave blank on unrestricted networks.
# REQUESTS_CA_BUNDLE=/path/to/your/ca-bundle.pem

# ── Corporate / TLS-inspecting proxy (optional) ───────────────────────────
# If your network uses a TLS-intercepting proxy (e.g. Netskope, Zscaler),
# point this to your corporate CA bundle so outbound HTTPS calls succeed.
# The server reads this at startup; leave blank on unrestricted networks.
# REQUESTS_CA_BUNDLE=/path/to/your/ca-bundle.pem
